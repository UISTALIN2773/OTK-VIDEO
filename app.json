{
  "expo": {
    "name": "OTK VIDEO",
    "slug": "otk-video",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.otkvideo.app",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "MEDIA_LIBRARY"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Permite acceder a la galería para guardar tus descargas.",
          "savePhotosPermission": "Permite guardar videos descargados en la galería.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "922bf2ea-ddfd-4e46-8a40-6d2c779f04c3"
      }
    }
  }
}
